# Copy to web/.env.local and fill in. .env.local is gitignored — never commit secrets.

# Your Anthropic API key. Get one at https://console.anthropic.com/
# Set a spend cap on this key in the console — the agent runs on visitor requests.
ANTHROPIC_API_KEY=sk-ant-...

# The shared password that gates the whole site (the "join code" you give visitors).
# Leave empty to disable the gate entirely (NOT recommended for a public deployment —
# the analysis agent executes code). It is inlined into the edge middleware at build
# time, so re-run `npm run build` after changing it.
SITE_PASSWORD=changeme

# Absolute path to a Python interpreter that has pandas, numpy, matplotlib, seaborn.
# Locally this can be a virtualenv or conda env; in production it's the sandboxed
# interpreter (see deploy/). Example: /home/appuser/venv/bin/python
VENV_PYTHON=/usr/bin/python3

# Port the Next.js server listens on (nginx / your proxy forwards to this).
PORT=3006
